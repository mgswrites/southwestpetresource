---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title, description, schema } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || 'A regional directory of pet care resources in Arizona, New Mexico, and Colorado.'} />
    <title>{title ? `${title} | SW Pet Resource` : 'SW Pet Resource'}</title>
    {schema ? <script type="application/ld+json" set:html={JSON.stringify(schema)} /> : null}
  </head>
  <body>
    <div class="header-bar">
      <Header />
    </div>
    <main>
      <slot />
    </main>
    <div class="footer-bar">
      <Footer />
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    line-height: 1.5;
    --bg: #edf4ef;
    --surface: #f7fbf8;
    --text: #1a2b22;
    --muted: #4e6b5e;
    --sage: #5a8272;
    --sage-dark: #3a5e50;
    --sage-soft: #c4d9ce;
    --sage-xsoft: #dceee5;
    --blue: #2563eb;
    --blue-dark: #1d4ed8;
    --blue-soft: #dbeafe;
    --border: #c4d9ce;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
  }

  a { color: var(--blue); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* full-width header stripe */
  .header-bar {
    background: var(--surface);
    border-bottom: 3px solid var(--sage);
    box-shadow: 0 2px 8px rgba(58, 94, 80, 0.07);
  }

  /* full-width footer stripe */
  .footer-bar {
    background: var(--surface);
    border-top: 1px solid var(--border);
    margin-top: 3rem;
  }

  header, main, footer { max-width: 1080px; margin: 0 auto; padding: 1rem 1.25rem; }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .brand { font-size: 1.2rem; font-weight: 700; color: var(--sage-dark); }
  .brand:hover { text-decoration: none; color: var(--sage); }
  .tagline { margin: 0.2rem 0 0; color: var(--muted); font-size: 0.88rem; }

  nav { display: flex; gap: 0.25rem; }
  nav a {
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 500;
    transition: background 0.12s, color 0.12s;
  }
  nav a:hover { background: var(--sage-xsoft); color: var(--sage-dark); text-decoration: none; }
  nav a.active { background: var(--sage); color: #fff; font-weight: 600; }

  main { padding-bottom: 3rem; }

  /* hero */
  .hero {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--sage);
    border-radius: 12px;
    padding: 1.75rem 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 3px 16px rgba(58, 94, 80, 0.07);
  }
  .hero h1 { margin-top: 0; font-size: 1.9rem; color: var(--sage-dark); line-height: 1.25; }
  .hero p { color: var(--muted); margin-bottom: 0; }

  /* cards */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 2px 10px rgba(58, 94, 80, 0.05);
    transition: box-shadow 0.15s, border-color 0.15s, transform 0.15s;
  }
  .card:hover {
    box-shadow: 0 6px 22px rgba(58, 94, 80, 0.11);
    border-color: var(--sage-soft);
    transform: translateY(-2px);
  }
  .card h3 { margin-top: 0; margin-bottom: 0.35rem; }

  /* panel (listing detail) */
  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
  }

  /* grid + list */
  .grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .list { display: grid; gap: 0.875rem; }

  /* helpers */
  .meta { color: var(--muted); font-size: 0.88rem; margin: 0.2rem 0; }

  .pill {
    display: inline-block;
    margin-right: 0.35rem;
    margin-bottom: 0.35rem;
    padding: 0.28rem 0.65rem;
    background: var(--sage-xsoft);
    color: var(--sage-dark);
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 500;
  }
  .pill-blue {
    background: var(--blue-soft);
    color: var(--blue-dark);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
  }
  .badge-verified { background: var(--sage-xsoft); color: var(--sage-dark); }
  .badge-blue { background: var(--blue-soft); color: var(--blue-dark); }

  .btn-link {
    display: inline-block;
    margin-top: 0.8rem;
    padding: 0.42rem 0.9rem;
    background: var(--blue);
    color: #fff;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    transition: background 0.12s;
  }
  .btn-link:hover { background: var(--blue-dark); text-decoration: none; }

  .section { margin-top: 2rem; }
  .section h2 { margin-bottom: 0.85rem; color: var(--sage-dark); }

  footer { color: var(--muted); font-size: 0.88rem; padding-top: 1.25rem; padding-bottom: 1.25rem; }
</style>
