---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title, description, schema } = Astro.props;
const siteUrl = 'https://www.southwestpetresource.com';
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const pageTitle = title ? `${title} | SW Pet Resource` : 'SW Pet Resource';
const pageDesc = description || 'A regional directory of pet resources in Arizona, New Mexico, Colorado, and the American Southwest.';
const ogImage = `https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=1200&h=630&fit=crop&auto=format`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="description" content={pageDesc} />
    <title>{pageTitle}</title>
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SW Pet Resource" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />
    {schema ? <script type="application/ld+json" set:html={JSON.stringify(schema)} /> : null}
  </head>
  <body>
    <div class="header-bar">
      <Header />
    </div>
    <main>
      <slot />
    </main>
    <div class="footer-bar">
      <Footer />
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    line-height: 1.5;
    --bg: #edf4ef;
    --surface: #f7fbf8;
    --text: #1a2b22;
    --muted: #4e6b5e;
    --sage: #5a8272;
    --sage-dark: #3a5e50;
    --sage-soft: #c4d9ce;
    --sage-xsoft: #dceee5;
    --blue: #2563eb;
    --blue-dark: #1d4ed8;
    --blue-soft: #dbeafe;
    --border: #c4d9ce;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    color: var(--text);
    background-color: var(--bg);
    background-image:
      linear-gradient(rgba(237,244,239,0.72), rgba(237,244,239,0.72)),
      url('https://images.unsplash.com/photo-1548199973-03cce0bbc87b?w=1920&auto=format&fit=crop&q=80');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }

  a { color: var(--sage-dark); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* full-width header stripe */
  .header-bar {
    background: var(--surface);
    border-bottom: 3px solid var(--sage);
    box-shadow: 0 2px 8px rgba(58, 94, 80, 0.07);
  }

  /* full-width footer stripe */
  .footer-bar {
    background: var(--surface);
    border-top: 3px solid var(--sage);
    box-shadow: 0 -2px 8px rgba(58, 94, 80, 0.07);
    margin-top: 3rem;
  }

  main, footer { max-width: 1080px; margin: 0 auto; padding: 1rem 1.25rem; }

  header {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
  }
  .brand-wrap { flex-shrink: 0; }

  .brand { font-size: 1.2rem; font-weight: 700; color: var(--sage-dark); }
  .brand:hover { text-decoration: none; color: var(--sage); }
  .tagline { margin: 0.2rem 0 0; color: var(--muted); font-size: 0.88rem; }

  nav { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  nav a {
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 500;
    white-space: nowrap;
    transition: background 0.12s, color 0.12s;
  }
  nav a:hover { background: var(--sage-xsoft); color: var(--sage-dark); text-decoration: none; }
  nav a.active { background: var(--sage); color: #fff; font-weight: 600; }

  main { padding-bottom: 3rem; }

  /* hero */
  .hero {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--sage);
    border-radius: 12px;
    padding: 1.75rem 2rem;
    margin-bottom: 2rem;
    box-shadow: 0 3px 16px rgba(58, 94, 80, 0.07);
  }
  .hero h1 { margin-top: 0; font-size: 1.9rem; color: var(--sage-dark); line-height: 1.25; }
  .hero p { color: var(--muted); margin-bottom: 0; }

  /* cards */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 2px 10px rgba(58, 94, 80, 0.05);
    transition: box-shadow 0.15s, border-color 0.15s, transform 0.15s;
  }
  .card:hover {
    box-shadow: 0 6px 22px rgba(58, 94, 80, 0.11);
    border-color: var(--sage-soft);
    transform: translateY(-2px);
  }
  .card h3 { margin-top: 0; margin-bottom: 0.35rem; }

  /* panel (listing detail) */
  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
  }

  /* grid + list */
  .grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .list { display: grid; gap: 0.875rem; }

  /* helpers */
  .meta { color: var(--muted); font-size: 0.88rem; margin: 0.2rem 0; }

  .pill {
    display: inline-block;
    margin-right: 0.35rem;
    margin-bottom: 0.35rem;
    padding: 0.28rem 0.65rem;
    background: var(--sage-xsoft);
    color: var(--sage-dark);
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 500;
  }
  .hero-home .pill {
    background: rgba(255,255,255,0.15);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.35);
    backdrop-filter: blur(6px);
  }
  .pill-blue {
    background: var(--blue-soft);
    color: var(--blue-dark);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
  }
  .badge-verified { background: var(--sage-xsoft); color: var(--sage-dark); }
  .badge-blue { background: var(--blue-soft); color: var(--blue-dark); }

  .btn-link {
    display: inline-block;
    margin-top: 0.8rem;
    padding: 0.42rem 0.9rem;
    background: var(--blue);
    color: #fff;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    transition: background 0.12s;
  }
  .btn-link:hover { background: var(--blue-dark); text-decoration: none; }

  .section { margin-top: 2rem; }
  .section h2 { margin-bottom: 0.85rem; color: var(--sage-dark); }

  /* breadcrumb nav */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--muted);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--sage-dark); text-decoration: underline; }
  .breadcrumb .sep { opacity: 0.5; }

  /* guide prose */
  .guide-body { max-width: 720px; }
  .guide-body h2 { color: var(--sage-dark); font-size: 1.3rem; margin-top: 2rem; margin-bottom: 0.5rem; }
  .guide-body h3 { color: var(--sage-dark); font-size: 1.05rem; margin-top: 1.5rem; margin-bottom: 0.35rem; }
  .guide-body p { line-height: 1.75; margin-bottom: 1rem; }
  .guide-body ul, .guide-body ol { padding-left: 1.4rem; margin-bottom: 1rem; }
  .guide-body li { line-height: 1.7; margin-bottom: 0.35rem; }
  .guide-body a { color: var(--sage-dark); }
  .guide-body strong { color: var(--text); }

  footer { color: var(--muted); font-size: 0.88rem; padding-top: 1.25rem; padding-bottom: 1.25rem; }
</style>
