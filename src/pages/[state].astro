---
import BaseLayout from '../layouts/BaseLayout.astro';
import { STATES, type State } from '../lib/states';
import { getRegionsByState, getCategories } from '../lib/data';

export async function getStaticPaths() {
  return STATES.map((s) => ({ params: { state: s.slug }, props: { state: s } }));
}

const { state } = Astro.props as { state: State };
const [regions, categories] = await Promise.all([
  getRegionsByState(state.abbr),
  getCategories(),
]);
const hasCities = regions.length > 0;
---

<BaseLayout
  title={`Pet Care in ${state.name}`}
  description={`Find veterinarians, boarding, groomers, pet supply stores, and pet-friendly lodging in ${state.name}.`}
>
  <div class="state-banner">
    <img src={state.image} alt={`${state.name} landscape`} class="banner-img" />
    <div class="banner-overlay" />
    <div class="banner-text">
      <p class="pill pill-white">{state.abbr} · Southwest Pet Resource</p>
      <h1>Pet care in {state.name}</h1>
      <p>Browse trusted pet care resources across {state.name}.</p>
    </div>
  </div>

  {hasCities ? (
    <>
      <section class="section">
        <h2>Cities</h2>
        <div class="city-grid">
          {regions.map((region) => (
            <a href={`/${state.slug}/${region.slug}`} class="city-card">
              {region.name}
            </a>
          ))}
        </div>
      </section>

      <section class="section">
        <h2>Browse by category</h2>
        <div class="grid">
          {categories.map((cat) => (
            <a href={`/listings/${cat.slug}/${regions[0].slug}`} class="card cat-card">
              <span class="cat-icon">{cat.icon}</span>
              <span class="cat-name">{cat.name}</span>
            </a>
          ))}
        </div>
      </section>
    </>
  ) : (
    <section class="section">
      <div class="coming-soon">
        <p>We're expanding to {state.name} soon.</p>
        <p>Check back for local listings.</p>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .state-banner {
    position: relative;
    width: calc(100% + 2.5rem);
    margin: -1rem -1.25rem 0;
    height: 340px;
    overflow: hidden;
    border-radius: 0;
  }
  .banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.2) 55%, rgba(0,0,0,0.05) 100%);
  }
  .banner-text {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 1.5rem;
    color: #fff;
  }
  .banner-text h1 {
    margin: 0.35rem 0 0.4rem;
    font-size: 2rem;
    color: #fff;
    line-height: 1.2;
  }
  .banner-text p { margin: 0; opacity: 0.88; font-size: 0.95rem; }
  .pill-white {
    background: rgba(255,255,255,0.18);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.3);
    backdrop-filter: blur(4px);
  }
  .city-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  }
  .city-card {
    display: block;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--sage-dark);
    text-align: center;
    text-decoration: none;
    transition: box-shadow 0.15s, border-color 0.15s, transform 0.15s;
    box-shadow: 0 2px 8px rgba(58,94,80,0.05);
  }
  .city-card:hover {
    border-color: var(--sage);
    box-shadow: 0 5px 18px rgba(58,94,80,0.11);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .cat-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-decoration: none;
    color: var(--text);
  }
  .cat-card:hover { text-decoration: none; }
  .cat-icon { font-size: 1.6rem; }
  .cat-name { font-size: 0.9rem; font-weight: 600; }
  .coming-soon {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2.5rem 2rem;
    text-align: center;
    color: var(--muted);
  }
  .coming-soon p { margin: 0.25rem 0; }
</style>
