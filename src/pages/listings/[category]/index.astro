---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCategories, getCategoryBySlug, getCitiesForCategory } from '../../../lib/data';
import { STATES } from '../../../lib/states';

export async function getStaticPaths() {
  const categories = await getCategories();
  return categories.map(cat => ({ params: { category: cat.slug } }));
}

const { category } = Astro.params;
const [cat, cities] = await Promise.all([
  getCategoryBySlug(category),
  getCitiesForCategory(category),
]);

const stateNames = Object.fromEntries(STATES.map(s => [s.abbr, s.name]));

const byState = new Map<string, typeof cities>();
for (const city of cities) {
  if (!byState.has(city.state)) byState.set(city.state, []);
  byState.get(city.state)!.push(city);
}
---

<BaseLayout
  title={cat?.name ?? category}
  description={`Find ${cat?.name?.toLowerCase() ?? category} across Arizona, New Mexico, Colorado, and the Southwest.`}
>
  <section class="hero">
    <p class="pill">Browse by category</p>
    <h1>{cat?.name}</h1>
    {cat?.description && <p>{cat.description}</p>}
  </section>

  {[...byState.entries()].map(([abbr, stateCities]) => (
    <section class="section">
      <h2>{stateNames[abbr] ?? abbr}</h2>
      <div class="city-grid">
        {stateCities.map(city => (
          <a href={`/listings/${category}/${city.slug}`} class="city-pill">
            {city.name}
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .city-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .city-pill {
    padding: 0.4rem 0.9rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 500;
    transition: background 0.12s, border-color 0.12s;
  }
  .city-pill:hover {
    background: var(--sage-xsoft);
    border-color: var(--sage-soft);
    color: var(--sage-dark);
    text-decoration: none;
  }
</style>
