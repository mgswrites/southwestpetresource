---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ListingCard from '../../../components/ListingCard.astro';
import { getCategories, getCategoryBySlug, getListingsForCategoryAndCity, getRegionBySlug, getRegions } from '../../../lib/data';
import { STATES } from '../../../lib/states';

export async function getStaticPaths() {
  const [categories, regions] = await Promise.all([getCategories(), getRegions()]);
  return categories.flatMap((category) =>
    regions.map((region) => ({
      params: { category: category.slug, city: region.slug },
      props: { categorySlug: category.slug, citySlug: region.slug },
    }))
  );
}

const { categorySlug, citySlug } = Astro.props;
const [category, region, listings] = await Promise.all([
  getCategoryBySlug(categorySlug),
  getRegionBySlug(citySlug),
  getListingsForCategoryAndCity(categorySlug, citySlug),
]);
const stateData = region ? STATES.find(s => s.abbr === region.state) : null;
---

<BaseLayout title={`${category?.name || categorySlug} in ${region?.name || citySlug}`} description={`Find ${category?.name?.toLowerCase() || categorySlug} in ${region?.name || citySlug}, ${region?.state || ''}.`}>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="sep" aria-hidden="true">›</span>
    <a href={`/listings/${categorySlug}`}>{category?.name || categorySlug}</a>
    <span class="sep" aria-hidden="true">›</span>
    {stateData && <><a href={`/${stateData.slug}`}>{stateData.name}</a><span class="sep" aria-hidden="true">›</span></>}
    <span>{region?.name || citySlug}</span>
  </nav>

  <section class="hero">
    <h1>{category?.name || categorySlug} in {region?.name || citySlug}</h1>
    <p>Browse trusted {category?.name?.toLowerCase() || 'pet resources'} in {region?.name || citySlug}{stateData ? `, ${stateData.name}` : ''}.</p>
  </section>

  <section class="section">
    {listings.length > 0 ? (
      <div class="list">
        {listings.map((listing) => <ListingCard listing={listing} />)}
      </div>
    ) : (
      <p>No listings have been added for this category and city yet. The site is ready for your seed data rollout.</p>
    )}
  </section>
</BaseLayout>
