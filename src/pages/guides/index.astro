---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuideCard from '../../components/GuideCard.astro';
import { getGuides } from '../../lib/data';

const guides = await getGuides();
---

<BaseLayout title="Guides" description="Editorial guides for choosing vets, finding low-cost clinics, and caring for rescue pets.">
  <section class="hero">
    <h1>Guides for pet owners and adopters</h1>
    <p>Helpful articles for navigating vet care, rescue transitions, and local resources.</p>
  </section>

  <section class="section">
    <div class="guide-grid">
      {guides.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .guide-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  @media (max-width: 900px) {
    .guide-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .guide-grid { grid-template-columns: 1fr; }
  }
</style>
