---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListingCard from '../components/ListingCard.astro';
import GuideCard from '../components/GuideCard.astro';
import { getCategories, getFeaturedListings, getGuides, getRegions } from '../lib/data';

const [categories, regions, featuredListings, guides] = await Promise.all([
  getCategories(),
  getRegions(),
  getFeaturedListings(),
  getGuides(),
]);
---

<BaseLayout title="Home" description="A Southwest regional directory of pet care resources for vets, rescues, groomers, trainers, boarding, and more.">
  <section class="hero">
    <p class="pill">Regional pet care directory</p>
    <h1>Find trusted pet care resources across Arizona, New Mexico, and Colorado.</h1>
    <p>SW Pet Resource highlights veterinarians, rescues, groomers, trainers, boarding options, and pet-friendly places to play.</p>
  </section>

  <section class="section">
    <h2>Popular categories</h2>
    <div class="grid">
      {categories.slice(0, 6).map((category) => (
        <article class="card">
          <div class="cat-icon">{category.icon}</div>
          <h3>{category.name}</h3>
          <p class="meta">{category.description}</p>
          <a href={`/listings/${category.slug}/${regions[0].slug}`} class="btn-link">Explore {regions[0].name}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Featured listings</h2>
    <div class="list">
      {featuredListings.map((listing) => <ListingCard listing={listing} />)}
    </div>
  </section>

  <section class="section">
    <h2>Helpful guides</h2>
    <div class="list">
      {guides.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>

<style>
  .cat-icon { font-size: 1.75rem; margin-bottom: 0.4rem; }
  .card h3 { margin-bottom: 0.25rem; font-size: 1rem; }
</style>
</BaseLayout>
