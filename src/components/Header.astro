---
const currentPath = Astro.url.pathname;
const leftNav = [
  { href: '/', label: 'Home' },
];
const catNav = [
  { href: '/listings/veterinary-clinics',    label: 'Veterinarians' },
  { href: '/listings/boarding-daycare',      label: 'Boarding & Daycare' },
  { href: '/listings/pet-supply',            label: 'Pet Supply' },
  { href: '/listings/pet-friendly-lodging',  label: 'Pet-Friendly Lodging' },
];
const rightNav = [
  { href: '/guides', label: 'Guides' },
  { href: '/about', label: 'About' },
  { href: '/search', label: 'Search' },
];
---

<header>
  <div class="header-left">
    <a href="/" class="brand">
      <img src="/icon.svg" alt="SW Pet Resource logo" class="brand-icon" />
      <span class="brand-text">SW Pet Resource</span>
    </a>
    <nav aria-label="Site navigation" class="nav-left">
      {leftNav.map(item => (
        <a href={item.href} class={currentPath === item.href ? 'active' : ''}>{item.label}</a>
      ))}
      <span class="divider" aria-hidden="true"></span>
      {catNav.map(item => (
        <a href={item.href} class={`cat-link${currentPath.startsWith(item.href) ? ' active' : ''}`}>{item.label}</a>
      ))}
    </nav>
  </div>
  <nav aria-label="Utility navigation" class="nav-right">
    {rightNav.map(item => (
      <a href={item.href} class={currentPath === item.href ? 'active' : ''}>{item.label}</a>
    ))}
  </nav>
</header>

<style>
  .header-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .brand:hover { text-decoration: none; }
  .brand-icon {
    height: 44px;
    width: 44px;
  }
  .brand-text {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--sage-dark);
    white-space: nowrap;
  }
  .brand:hover .brand-text { color: var(--sage); }
  .divider {
    display: inline-block;
    width: 1px;
    height: 1rem;
    background: var(--border);
    margin: 0 0.25rem;
    vertical-align: middle;
  }
  .cat-link {
    font-size: 0.8rem;
  }

  /* mobile: stack nav below brand */
  @media (max-width: 720px) {
    header {
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .header-left {
      flex-wrap: wrap;
      width: 100%;
    }
    nav {
      flex-wrap: wrap;
      width: 100%;
    }
    .divider { display: none; }
  }
</style>
